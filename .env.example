# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Gmail auth config ID
# Get these from https://composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your_gmail_auth_config_id_here

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001

# Optional: CORS configuration
# OPENPOKE_CORS_ALLOW_ORIGINS=*

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs

# ── APM Layer (Local APM + Hierarchical Thread Caching) ────────────────────────
# Options: "ollama" (local, no API key) | "gemini" | "openai"
LLM_PROVIDER=ollama

# Ollama — local inference, no API key needed
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434

# Gemini — get key at https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# PostgreSQL (started via docker-compose)
DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/open_poke

# Redis (started via docker-compose)
REDIS_URL=redis://localhost:6379/0

# Sub-agent credentials (optional — stubs work without these)
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# GMAIL_CREDENTIALS_PATH=
